import("../src/fard_isa_registers") as regs
import("../src/fard_isa_types") as ty

test "register count is 64" {
  // Increased from 32 -> 64 to accommodate FARD Prim's post-RA/peephole
  // OMIR via fard_isa_regmap: 16 named x86-64 registers (indices 1-16)
  // plus up to 32 stack slots (indices 32-63), with index 0 reserved as
  // r_zero. See fard_isa_regmap.fard and
  // tests/test_retirement_reduction.fard (fib's post-RA OMIR uses stack
  // slots down to -136, i.e. 17 slots, which a 32-register file with
  // R_FP/R_SP also reserved could not address).
  regs.REG_COUNT == 64
}

test "valid registers are 0 through 63" {
  regs.valid_reg(0) && regs.valid_reg(63) && !regs.valid_reg(64)
}

test "r_zero reads unit" {
  let rf = {} in
  regs.read(rf, regs.R_ZERO).tag == ty.TAG_UNIT
}

test "writes to r_zero are ignored" {
  let rf = regs.write({}, regs.R_ZERO, ty.fardval_int(42)) in
  regs.read(rf, regs.R_ZERO).tag == ty.TAG_UNIT
}

test "write then read normal register" {
  let rf = regs.write({}, regs.R_RET, ty.fardval_int(42)) in
  regs.read(rf, regs.R_RET).payload == 42
}

test "abi arg register mapping" {
  regs.abi_arg_reg(0) == regs.R_ARG0 && regs.abi_arg_reg(5) == regs.R_ARG5
}
