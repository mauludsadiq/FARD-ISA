import("../src/fard_isa_opcodes") as op
import("../src/fard_isa_types") as ty
import("../src/omir_to_fard_isa") as lower
import("../src/fard_isa_sim") as sim
import("../src/canonical_event_v1") as event
import("std/list") as list

test "sim add 40 and 2" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let program = [
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 40, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(40))
    ]),
    lower.isa_instr(op.LOAD_IMM64, 2, 0, 0, 2, [
      lower.operand(1, 16, ty.hex16(2)),
      lower.operand(2, 64, ty.hex64(2))
    ]),
    lower.isa_instr(op.ADD_SLOT, 1, 0, 0, 2, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(3, 64, ty.hex64(2))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let final = sim.run(program, ty.initial_state(1, genesis), 20) in
  final.regs["1"].payload == 42
}

test "sim FVAL.CHECK_TAG succeeds for int" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let program = [
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 42, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(42))
    ]),
    lower.isa_instr(op.FVAL_CHECK_TAG, 2, 1, 0, ty.TAG_INT, [
      lower.operand(1, 16, ty.hex16(2)),
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(6, 32, ty.hex32(ty.TAG_INT))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let final = sim.run(program, ty.initial_state(1, genesis), 20) in
  final.regs["2"].payload == 1
}

test "sim FVAL.CHECK_TAG traps on wrong tag" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let program = [
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 42, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(42))
    ]),
    lower.isa_instr(op.FVAL_CHECK_TAG, 2, 1, 0, ty.TAG_BOOL, [
      lower.operand(1, 16, ty.hex16(2)),
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(6, 32, ty.hex32(ty.TAG_BOOL))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let final = sim.run(program, ty.initial_state(1, genesis), 20) in
  final.halted == true && list.len(final.events) == 2
}

test "sim STORE.MEM64 then LOAD.MEM64 emits memory digests" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let program = [
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 100, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(100))
    ]),
    lower.isa_instr(op.LOAD_IMM64, 2, 0, 0, 42, [
      lower.operand(1, 16, ty.hex16(2)),
      lower.operand(2, 64, ty.hex64(42))
    ]),
    lower.isa_instr(op.STORE_MEM64, 1, 2, 0, 0, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(1, 16, ty.hex16(2))
    ]),
    lower.isa_instr(op.LOAD_MEM64, 3, 1, 0, 0, [
      lower.operand(1, 16, ty.hex16(3)),
      lower.operand(1, 16, ty.hex16(1))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let final = sim.run(program, ty.initial_state(1, genesis), 20) in
  final.regs["3"].payload == 42 &&
  list.len(final.events) == 5 &&
  final.memory_root != ty.memory_root({})
}

test "sim FVAL_BOX_I64 boxes integer payload with canonical event evidence" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let empty_write = event.reg_write_digest([]) in
  let program = [
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 77, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(77))
    ]),
    lower.isa_instr(op.FVAL_BOX_I64, 2, 1, 0, 0, [
      lower.operand(1, 16, ty.hex16(2)),
      lower.operand(1, 16, ty.hex16(1))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let final = sim.run(program, ty.initial_state(1, genesis), 20) in
  let box_ev = list.get(final.events, 1) in
  final.regs["2"].tag == ty.TAG_INT &&
  final.regs["2"].payload == 77 &&
  list.len(final.events) == 3 &&
  box_ev["event_obj"].opcode == op.FVAL_BOX_I64 &&
  box_ev["register_write_digest"] != empty_write &&
  final.receipt != genesis
}

test "sim FVAL_UNBOX_I64 extracts int payload with canonical event evidence" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let empty_read = event.reg_read_digest([]) in
  let empty_write = event.reg_write_digest([]) in
  let program = [
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 123, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(123))
    ]),
    lower.isa_instr(op.FVAL_BOX_I64, 2, 1, 0, 0, [
      lower.operand(1, 16, ty.hex16(2)),
      lower.operand(1, 16, ty.hex16(1))
    ]),
    lower.isa_instr(op.FVAL_UNBOX_I64, 3, 2, 0, 0, [
      lower.operand(1, 16, ty.hex16(3)),
      lower.operand(1, 16, ty.hex16(2))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let final = sim.run(program, ty.initial_state(1, genesis), 20) in
  let unbox_ev = list.get(final.events, 2) in
  final.regs["3"].tag == ty.TAG_INT &&
  final.regs["3"].payload == 123 &&
  list.len(final.events) == 4 &&
  unbox_ev.opcode == op.FVAL_UNBOX_I64 &&
  unbox_ev.register_read_digest != empty_read &&
  unbox_ev.register_write_digest != empty_write &&
  final.receipt != genesis
}

test "sim FVAL_UNBOX_I64 traps on non-int tag with canonical event evidence" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let empty_read = event.reg_read_digest([]) in
  let empty_write = event.reg_write_digest([]) in
  let initial = ty.initial_state(1, genesis) in
  let regs = ty.reg_set(initial.regs, 1, ty.fardval_bool(true)) in
  let state = { ...initial, regs: regs } in
  let program = [
    lower.isa_instr(op.FVAL_UNBOX_I64, 2, 1, 0, 0, [
      lower.operand(1, 16, ty.hex16(2)),
      lower.operand(1, 16, ty.hex16(1))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let final = sim.run(program, state, 20) in
  let trap_ev = list.get(final.events, 0) in
  final.halted == true &&
  list.len(final.events) == 1 &&
  trap_ev.opcode == op.FVAL_UNBOX_I64 &&
  trap_ev.register_read_digest != empty_read &&
  trap_ev.register_write_digest == empty_write &&
  trap_ev.trap_digest != event.trap_digest_none() &&
  final.receipt != genesis
}

test "sim LOAD_ARG copies source register into ABI arg register with event evidence" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let empty_read = event.reg_read_digest([]) in
  let empty_write = event.reg_write_digest([]) in
  let program = [
    lower.isa_instr(op.LOAD_IMM64, 10, 0, 0, 88, [
      lower.operand(1, 16, ty.hex16(10)),
      lower.operand(2, 64, ty.hex64(88))
    ]),
    lower.isa_instr(op.LOAD_ARG, 0, 0, 0, 10, [
      lower.operand(4, 16, ty.hex16(0)),
      lower.operand(1, 16, ty.hex16(10))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let final = sim.run(program, ty.initial_state(1, genesis), 20) in
  let load_arg_ev = list.get(final.events, 1) in
  final.regs["2"].payload == 88 &&
  list.len(final.events) == 3 &&
  load_arg_ev.opcode == op.LOAD_ARG &&
  load_arg_ev.register_read_digest != empty_read &&
  load_arg_ev.register_write_digest != empty_write &&
  final.receipt != genesis
}

test "sim STORE_PARAM copies ABI arg register into destination register with event evidence" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let empty_read = event.reg_read_digest([]) in
  let empty_write = event.reg_write_digest([]) in
  let initial = ty.initial_state(1, genesis) in
  let regs0 = ty.reg_set(initial.regs, 2, ty.fardval_int(99)) in
  let state = { ...initial, regs: regs0 } in
  let program = [
    lower.isa_instr(op.STORE_PARAM, 0, 0, 0, 11, [
      lower.operand(4, 16, ty.hex16(0)),
      lower.operand(1, 16, ty.hex16(11))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let final = sim.run(program, state, 20) in
  let store_param_ev = list.get(final.events, 0) in
  final.regs["11"].payload == 99 &&
  list.len(final.events) == 2 &&
  store_param_ev.opcode == op.STORE_PARAM &&
  store_param_ev.register_read_digest != empty_read &&
  store_param_ev.register_write_digest != empty_write &&
  final.receipt != genesis
}

test "sim BR_NE takes branch when CMP_ZERO clears zero flag" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let program = [
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 7, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(7))
    ]),
    lower.isa_instr(op.CMP_ZERO, 0, 0, 0, 1, [
      lower.operand(1, 16, ty.hex16(1))
    ]),
    lower.isa_instr(op.BR_NE, 0, 0, 0, 64, [
      lower.operand(5, 64, ty.hex64(64))
    ]),
    lower.isa_instr(op.LOAD_IMM64, 2, 0, 0, 111, [
      lower.operand(1, 16, ty.hex16(2)),
      lower.operand(2, 64, ty.hex64(111))
    ]),
    lower.isa_instr(op.LOAD_IMM64, 2, 0, 0, 222, [
      lower.operand(1, 16, ty.hex16(2)),
      lower.operand(2, 64, ty.hex64(222))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let final = sim.run(program, ty.initial_state(1, genesis), 20) in
  let branch_ev = list.get(final.events, 2) in
  final.regs["2"].payload == 222 &&
  branch_ev.opcode == op.BR_NE &&
  branch_ev.event_obj.pc_after == 64 &&
  list.len(final.events) == 5 &&
  final.receipt != genesis
}

test "sim BR_NE falls through when CMP_ZERO sets zero flag" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let program = [
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 0, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(0))
    ]),
    lower.isa_instr(op.CMP_ZERO, 0, 0, 0, 1, [
      lower.operand(1, 16, ty.hex16(1))
    ]),
    lower.isa_instr(op.BR_NE, 0, 0, 0, 80, [
      lower.operand(5, 64, ty.hex64(80))
    ]),
    lower.isa_instr(op.LOAD_IMM64, 2, 0, 0, 111, [
      lower.operand(1, 16, ty.hex16(2)),
      lower.operand(2, 64, ty.hex64(111))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let final = sim.run(program, ty.initial_state(1, genesis), 20) in
  let branch_ev = list.get(final.events, 2) in
  final.regs["2"].payload == 111 &&
  branch_ev.opcode == op.BR_NE &&
  branch_ev.event_obj.pc_after == 48 &&
  list.len(final.events) == 5 &&
  final.receipt != genesis
}

test "sim BR_UNCOND always jumps to target with canonical event evidence" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let program = [
    lower.isa_instr(op.BR_UNCOND, 0, 0, 0, 48, [
      lower.operand(5, 64, ty.hex64(48))
    ]),
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 111, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(111))
    ]),
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 222, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(222))
    ]),
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 333, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(333))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let final = sim.run(program, ty.initial_state(1, genesis), 20) in
  let branch_ev = list.get(final.events, 0) in
  final.regs["1"].payload == 333 &&
  branch_ev.opcode == op.BR_UNCOND &&
  branch_ev.event_obj.pc_after == 48 &&
  list.len(final.events) == 3 &&
  final.receipt != genesis
}

test "sim CALL_REL32 jumps to target and RET_I64 returns to caller with event evidence" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let program = [
    lower.isa_instr(op.CALL_REL32, 0, 0, 0, 48, [
      lower.operand(5, 64, ty.hex64(48))
    ]),
    lower.isa_instr(op.LOAD_IMM64, 2, 0, 0, 9, [
      lower.operand(1, 16, ty.hex16(2)),
      lower.operand(2, 64, ty.hex64(9))
    ]),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, []),
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 42, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(42))
    ]),
    lower.isa_instr(op.RET_I64, 1, 0, 0, 0, [
      lower.operand(1, 16, ty.hex16(1))
    ])
  ] in
  let final = sim.run(program, ty.initial_state(1, genesis), 20) in
  let call_ev = list.get(final.events, 0) in
  let ret_ev = list.get(final.events, 2) in
  let halt_ev = list.get(final.events, 4) in
  final.regs["1"].payload == 42 &&
  final.regs["2"].payload == 9 &&
  final.halted == true &&
  final.pc == 32 &&
  list.len(final.call_stack) == 0 &&
  list.len(final.events) == 5 &&
  call_ev.opcode == op.CALL_REL32 &&
  call_ev.event_obj.pc_after == 48 &&
  ret_ev.opcode == op.RET_I64 &&
  ret_ev.event_obj.pc_after == 16 &&
  halt_ev.opcode == op.HALT &&
  final.receipt != genesis
}

test "sim RET_I64 with empty call stack halts as program return with event evidence" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let program = [
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 17, [
      lower.operand(1, 16, ty.hex16(1)),
      lower.operand(2, 64, ty.hex64(17))
    ]),
    lower.isa_instr(op.RET_I64, 1, 0, 0, 0, [
      lower.operand(1, 16, ty.hex16(1))
    ]),
    lower.isa_instr(op.LOAD_IMM64, 2, 0, 0, 999, [
      lower.operand(1, 16, ty.hex16(2)),
      lower.operand(2, 64, ty.hex64(999))
    ])
  ] in
  let final = sim.run(program, ty.initial_state(1, genesis), 20) in
  let ret_ev = list.get(final.events, 1) in
  final.halted == true &&
  final.regs["1"].payload == 17 &&
  ret_ev.opcode == op.RET_I64 &&
  ret_ev.register_read_digest != event.reg_read_digest([]) &&
  list.len(final.events) == 2 &&
  final.receipt != genesis
}
