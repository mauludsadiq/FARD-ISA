}

test "golden equivalence box unbox" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let p = [
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 77, []),
    lower.isa_instr(op.FVAL_BOX_I64, 2, 1, 0, 0, []),
    lower.isa_instr(op.FVAL_UNBOX_I64, 3, 2, 0, 0, []),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let r = golden_run(p, ty.initial_state(1, genesis), 20) in
  r.final.receipt == r.recomputed_receipt
}

test "golden equivalence load store param" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let p = [
    lower.isa_instr(op.LOAD_IMM64, 1, 0, 0, 88, []),
    lower.isa_instr(op.LOAD_ARG, 1, 1, 0, 0, []),
    lower.isa_instr(op.STORE_PARAM, 2, 0, 0, 0, []),
    lower.isa_instr(op.HALT, 0, 0, 0, 0, [])
  ] in
  let r = golden_run(p, ty.initial_state(1, genesis), 20) in
  r.final.receipt == r.recomputed_receipt
}

test "golden equivalence finalize" {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in
  let p = [
    lower.isa_instr(op.TRUST_FINALIZE, 0, 0, 0, 0, [])
  ] in
  let r = golden_run(p, ty.initial_state(1, genesis), 20) in
  r.final.receipt == r.recomputed_receipt
}
