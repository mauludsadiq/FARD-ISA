/// Multi-function module with heap allocation: get0([10,20,30]) = 10.
/// Exercises map_module's symbol table (fard_alloc + fard_main + get0
/// resolved via CallReloc), and the new LoadHeap/StoreHeap/LoadHeapDyn
/// mappings in omir_to_fard_isa_mem.

import("/Users/g.bogans/Downloads/FARD_v0.5/apps/fardlex")   as lex
import("/Users/g.bogans/Downloads/FARD_v0.5/apps/fardparse") as par
import("/Users/g.bogans/Downloads/FARD_v0.5/apps/fard_lower") as lower
import("/Users/g.bogans/Downloads/FARD Prim/src/orgntr_prim/fard_ir_to_ocir") as bridge
import("/Users/g.bogans/Downloads/FARD Prim/src/orgntr_prim/lower_ocir_to_omir") as omir_lower
import("/Users/g.bogans/Downloads/FARD Prim/src/orgntr_prim/omir_tco") as tco
import("/Users/g.bogans/Downloads/FARD Prim/src/orgntr_prim/omir_regalloc") as ra
import("/Users/g.bogans/Downloads/FARD Prim/src/orgntr_prim/omir_peephole") as peep
import("../src/omir_to_fard_isa_mem") as m
import("../src/fard_isa_sim") as sim
import("../src/fard_isa_types") as ty
import("std/list") as list
import("std/str") as str
import("std/rec") as rec

let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111"
let SP_BASE = 65536
let HEAP_BASE = 131072

fn compile_optimized(src) {
  let raw = tco.tco_module(omir_lower.lower_module(
    bridge.lower_module(
      lower.lower_program(par.parse_module(lex.tokenize(src), 0).node)))) in
  peep.peephole_module(ra.regalloc_module(raw)).funcs
}

test "get0([10,20,30]) = 10 via memory-backed FARD-ISA with multi-function symbol table" {
  let funcs = compile_optimized("fn get0(xs){xs[0]}\nget0([10,20,30])") in
  let m_out = m.map_module(funcs) in
  let prog = m_out.prog in
  let entry = rec.get(m_out.fn_table, "fard_main") in

  let state0 = ty.initial_state(1, genesis) in
  let regs1 = ty.reg_set(state0.regs, m.R_SP, ty.fardval_int(SP_BASE)) in
  let regs2 = ty.reg_set(regs1, m.R_BUMP, ty.fardval_int(HEAP_BASE)) in
  let state = { ...state0, regs: regs2, pc: entry * 16 } in

  let final = sim.run(prog, state, 2000) in
  final.halted && final.regs[str.from(m.RAX)].payload == 10
}

test "rec_field: r.a = 42 via memory-backed FARD-ISA with multi-function symbol table" {
  let funcs = compile_optimized("fn geta(r){r.a}\ngeta({a:42,b:7})") in
  let m_out = m.map_module(funcs) in
  let prog = m_out.prog in
  let entry = rec.get(m_out.fn_table, "fard_main") in

  let state0 = ty.initial_state(1, genesis) in
  let regs1 = ty.reg_set(state0.regs, m.R_SP, ty.fardval_int(SP_BASE)) in
  let regs2 = ty.reg_set(regs1, m.R_BUMP, ty.fardval_int(HEAP_BASE)) in
  let state = { ...state0, regs: regs2, pc: entry * 16 } in

  let final = sim.run(prog, state, 2000) in
  final.halted && final.regs[str.from(m.RAX)].payload == 42
}
