import("../src/golden_omir_interpreter") as golden
import("../src/omir_to_fard_isa") as lower
import("../src/fard_isa_sim") as sim
import("../src/fard_isa_types") as ty
import("../src/canonical_event_v1") as event
import("../src/epoch_receipt_v1") as epoch
import("std/list") as list

fn run_equiv(omir) {
  let genesis = "sha256:1111111111111111111111111111111111111111111111111111111111111111" in

  let g = golden.run(omir, genesis) in
  let isa = lower.map_program(omir) in
  let s = sim.run(isa, ty.initial_state(1, genesis), 1000) in

  {
    golden: g,
    sim: s
  }
}

test "Phase3 pipeline receipt add program" {
  let r = run_equiv([
    { kind: "mov_imm64", dst: 1, val: 40 },
    { kind: "mov_imm64", dst: 2, val: 2 },
    { kind: "add_slot", dst: 1, slot: 2 },
    { kind: "halt" }
  ]) in

  r.golden.final_state.regs["1"].payload == 42 &&
  r.sim.regs["1"].payload == 42 &&
  r.golden.epoch_receipt_v1.digest == epoch.receipt_digest(r.golden.epoch_receipt_v1)
}

test "Phase3 pipeline receipt branch program" {
  let r = run_equiv([
    { kind: "mov_imm64", dst: 1, val: 7 },
    { kind: "cmp_zero", slot: 1 },
    { kind: "br_ne", target: 4 },
    { kind: "mov_imm64", dst: 2, val: 111 },
    { kind: "mov_imm64", dst: 2, val: 222 },
    { kind: "halt" }
  ]) in

  r.golden.final_state.regs["2"].payload == 222 &&
  r.sim.regs["2"].payload == 222
}

test "Phase3 pipeline receipt call program" {
  let r = run_equiv([
    { kind: "call_rel32", target: 3 },
    { kind: "mov_imm64", dst: 2, val: 9 },
    { kind: "halt" },
    { kind: "mov_imm64", dst: 1, val: 42 },
    { kind: "ret_i64", src: 1 }
  ]) in

  r.golden.final_state.regs["1"].payload == 42 &&
  r.sim.regs["1"].payload == 42
}

test "Phase3 pipeline receipt trust finalize program" {
  let r = run_equiv([
    { kind: "trust_finalize" }
  ]) in

  r.golden.final_state.prior_epoch_digest != ty.zero_digest() &&
  r.sim.prior_epoch_digest != ty.zero_digest()
}
